// Remote Classroom Desktop — data model
// Postgres via Prisma. Run `npx prisma migrate dev` to apply.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Teacher {
  id        String      @id @default(cuid())
  email     String      @unique
  name      String
  password  String // bcrypt hash
  createdAt DateTime    @default(now())
  classes   Classroom[]
  templates ClassTemplate[]

  // Billing / plan
  plan                 String    @default("free") // free | pro
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  planStatus           String? // active | trialing | past_due | canceled
  currentPeriodEnd     DateTime?

  // Cost guardrails (null = no limit)
  maxConcurrentDesktops Int?
  monthlySpendCapCents  Int?
}

model Classroom {
  id                 String    @id @default(cuid())
  name               String
  joinCode           String    @unique // e.g. ABC-123
  teacherId          String
  teacher            Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  defaultOs          String    @default("linux") // linux | windows
  // Golden image: a specific Daytona snapshot to boot desktops from (null = OS default).
  snapshot           String?
  defaultDurationMin Int       @default(60) // time limit applied to machines
  allowStudentBoot   Boolean   @default(true) // students can boot their own machine
  idleTimeoutMin     Int       @default(20) // auto-stop a desktop after this many idle minutes (0 = never)
  // Internet policy applied to newly-booted desktops (Daytona network rules).
  netMode            String    @default("open") // open | allowlist | blocked
  allowedDomains     String? // comma-separated, used when netMode = allowlist
  // Exam mode: student banner + no self-shutdown; pair with a locked-down netMode.
  examMode           Boolean   @default(false)
  examMessage        String?
  // "Eyes on me" focus lock — when set, students see a full-screen lock over their desktop.
  lockedAt           DateTime?
  lockMessage        String?
  // Broadcast / spotlight: when set, every student sees a view-only stream of this machine.
  spotlightMachineId String?
  // Text announcement shown to every student as a dismissible banner (null = none).
  announcement       String?
  announcementAt     DateTime?
  // Require a per-student PIN to join (stops roster-name impersonation).
  requireJoinPin     Boolean   @default(false)
  createdAt          DateTime  @default(now())
  students           Student[]
  machines           Machine[]
  events             ClassEvent[]
  schedules          ClassSchedule[]
  groups             ClassGroup[]
}

// A group workstation: several students share one desktop + one persistent volume
// (pair programming, group projects). Every member can open and control the same machine.
model ClassGroup {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  name        String
  volumeId    String? // shared Daytona volume for the group (created on first boot)
  volumeName  String?
  createdAt   DateTime  @default(now())
  students    Student[]
  machines    Machine[]

  @@index([classroomId])
}

// A recurring weekly time slot that auto-boots a class's desktops.
model ClassSchedule {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  weekday     Int // 0=Sunday .. 6=Saturday (server local time)
  startMinute Int // minutes from midnight
  durationMin Int       @default(45)
  endMinute   Int? // optional bell time: auto-shut down the class at this minute-of-day
  os          String    @default("linux")
  enabled     Boolean   @default(true)
  lastRunOn   String? // "YYYY-MM-DD" guard so a slot fires once per day
  lastShutdownOn String? // "YYYY-MM-DD" guard so the bell shutdown fires once per day
  createdAt   DateTime  @default(now())

  @@index([classroomId])
}

// Append-only activity / audit trail for a class.
model ClassEvent {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  studentId   String?
  student     Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  type        String // boot | running | stopped | expired | error | lock | unlock | download | provision_all | shutdown_all
  message     String
  actorRole   String? // teacher | student | system
  createdAt   DateTime  @default(now())

  @@index([classroomId, createdAt])
}

// Reusable class blueprint a teacher can apply when creating a class.
model ClassTemplate {
  id               String   @id @default(cuid())
  teacherId        String
  teacher          Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  name             String
  os               String   @default("linux")
  durationMin      Int      @default(45)
  allowStudentBoot Boolean  @default(true)
  createdAt        DateTime @default(now())
}

model Student {
  id          String    @id @default(cuid())
  name        String
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  volumeId    String? // Daytona persistent volume id (created on first boot)
  volumeName  String?
  joinedAt    DateTime  @default(now())
  machines    Machine[]

  // Group workstation membership (null = works solo on their own desktop).
  groupId     String?
  group       ClassGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // Monthly desktop-time usage (for plan limits). usageMonth is "YYYY-MM".
  usageMonth   String?
  usageMinutes Int     @default(0)
  events       ClassEvent[]

  // Panic / "raise hand" flag — set when the student asks for help or reports content.
  flaggedAt  DateTime?
  flagKind   String? // help | report
  flagNote   String?

  // Optional bcrypt-hashed join PIN (set when the class requires one).
  joinPin    String?
  // Low-bandwidth desktop streaming preference (persisted per student).
  connectionSaver Boolean @default(false)

  @@unique([classroomId, name]) // one identity per name within a class
}

// One machine row per (active) desktop. Status drives the UI lifecycle.
model Machine {
  id           String    @id @default(cuid())
  classroomId  String
  classroom    Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  studentId    String?
  student      Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  // Set instead of studentId when this is a shared group workstation.
  groupId      String?
  group        ClassGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  os           String    @default("linux") // linux | windows
  status       String    @default("PENDING") // PENDING, PROVISIONING, RUNNING, STOPPING, STOPPED, EXPIRED, ERROR
  sandboxId    String? // Daytona sandbox id
  previewUrl   String? // same-origin proxied noVNC url to embed
  previewToken String? // Daytona private-preview token (injected by the proxy)
  errorMessage String?

  durationMin  Int       @default(60) // time limit in minutes
  startedAt    DateTime?
  expiresAt    DateTime? // hard stop time = startedAt + durationMin
  stoppedAt    DateTime?
  watchedUntil DateTime? // set by a teacher viewing/controlling; powers the student "being watched" banner

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([classroomId])
  @@index([studentId])
  @@index([groupId])
  @@index([status])
}
