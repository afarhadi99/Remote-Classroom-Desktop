// Remote Classroom Desktop — data model
// Postgres via Prisma. Run `npx prisma migrate dev` to apply.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Platform operator (super-admin) — oversees ALL teachers, subscriptions and desktops.
// Separate from Teacher; created out-of-band (seed script / env), never self-signup.
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String // bcrypt hash
  createdAt DateTime @default(now())
}

model Teacher {
  id        String      @id @default(cuid())
  email     String      @unique
  name      String
  password  String // bcrypt hash
  createdAt DateTime    @default(now())
  classes   Classroom[]
  templates ClassTemplate[]
  apiKeys   ApiKey[]
  webhooks  WebhookEndpoint[]

  // Billing / plan
  plan                 String    @default("free") // free | pro
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  planStatus           String? // active | trialing | past_due | canceled
  currentPeriodEnd     DateTime?

  // Cost guardrails (null = no limit)
  maxConcurrentDesktops Int?
  monthlySpendCapCents  Int?

  // LTI 1.3 just-in-time provisioning identity (set for teachers created via an LMS launch).
  ltiPlatformId String?
  ltiSub        String?

  @@unique([ltiPlatformId, ltiSub])
}

model Classroom {
  id                 String    @id @default(cuid())
  name               String
  joinCode           String    @unique // e.g. ABC-123
  teacherId          String
  teacher            Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  defaultOs          String    @default("linux") // linux | windows
  // Golden image: a specific Daytona snapshot to boot desktops from (null = OS default).
  snapshot           String?
  // OneRoster/SIS identity for idempotent roster sync (null = manually created).
  sourcedId          String?
  // LTI 1.3: the LMS context (course) this class is bound to, if launched from an LMS.
  ltiPlatformId      String?
  ltiContextId       String?
  // LTI Advantage service endpoints captured at launch (NRPS roster pull, AGS grade passback).
  ltiNrpsUrl         String?
  ltiAgsLineitemsUrl String?
  defaultDurationMin Int       @default(60) // time limit applied to machines
  allowStudentBoot   Boolean   @default(true) // students can boot their own machine
  idleTimeoutMin     Int       @default(20) // auto-stop a desktop after this many idle minutes (0 = never)
  // Internet policy applied to newly-booted desktops (Daytona network rules).
  netMode            String    @default("open") // open | allowlist | blocked
  allowedDomains     String? // comma-separated, used when netMode = allowlist
  // Exam mode: student banner + no self-shutdown; pair with a locked-down netMode.
  examMode           Boolean   @default(false)
  examMessage        String?
  // Safeguarding: comma-separated watch-terms; student notes/answers matching them raise an alert.
  safeguardKeywords  String?
  // Quiet hours: students may only self-boot when the minute-of-day is within this window
  // (server local time). null = always allowed. Wrap-around (overnight) supported.
  bootWindowStart    Int?
  bootWindowEnd      Int?
  // "Eyes on me" focus lock — when set, students see a full-screen lock over their desktop.
  lockedAt           DateTime?
  lockMessage        String?
  // Broadcast / spotlight: when set, every student sees a view-only stream of this machine.
  spotlightMachineId String?
  // Text announcement shown to every student as a dismissible banner (null = none).
  announcement       String?
  announcementAt     DateTime?
  // Require a per-student PIN to join (stops roster-name impersonation).
  requireJoinPin     Boolean   @default(false)
  createdAt          DateTime  @default(now())
  students           Student[]
  machines           Machine[]
  events             ClassEvent[]
  schedules          ClassSchedule[]
  groups             ClassGroup[]
  assignments        Assignment[]
  polls              Poll[]

  @@unique([ltiPlatformId, ltiContextId])
  @@index([teacherId, sourcedId])
}

// An assignment closes the assign -> collect -> return loop. Submission.score is the canonical
// grade record that LTI AGS passback reads.
model Assignment {
  id            String       @id @default(cuid())
  classroomId   String
  classroom     Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  title         String
  collectFolder String       @default("Turn-in")
  createdAt     DateTime     @default(now())
  submissions   Submission[]
  // LTI AGS line item URL (created in the LMS gradebook on first passback).
  ltiLineItemUrl String?

  @@index([classroomId])
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String     @default("assigned") // assigned | collected | returned | graded
  score        Int?
  scoreMax     Int?
  feedback     String?
  updatedAt    DateTime   @updatedAt

  @@unique([assignmentId, studentId])
}

// A registered LTI 1.3 platform (LMS): Canvas, Schoology, Moodle, Blackboard, D2L, etc.
model LtiPlatform {
  id            String   @id @default(cuid())
  issuer        String
  clientId      String
  authLoginUrl  String // platform OIDC authorization endpoint
  authTokenUrl  String // platform OAuth2 token endpoint (for NRPS/AGS)
  jwksUrl       String // platform public keys
  deploymentIds String // comma-separated allowed deployment_ids
  createdAt     DateTime @default(now())

  @@unique([issuer, clientId])
}

// Our tool's signing keypair (served at /api/lti/jwks.json). Generated once.
model LtiKey {
  id         String   @id @default(cuid())
  kid        String   @unique
  publicJwk  String // JSON
  privatePem String
  createdAt  DateTime @default(now())
}

// Cached OAuth2 client-credentials bearer for LTI Advantage service calls (NRPS/AGS).
model LtiServiceToken {
  id          String   @id @default(cuid())
  platformId  String
  scopeKey    String // sorted, space-joined scopes
  accessToken String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([platformId, scopeKey])
}

// A durable AGS grade-passback job (reuses the webhook backoff + dead-letter shape).
model LtiGradeJob {
  id           String    @id @default(cuid())
  classroomId  String
  assignmentId String
  studentId    String
  scoreGiven   Int
  scoreMaximum Int
  comment      String?
  status       String    @default("pending") // pending | delivered | failed | dead
  attempts     Int       @default(0)
  nextAttemptAt DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, nextAttemptAt])
}

// Single-use OIDC state+nonce for the launch handshake (CSRF + replay protection).
model LtiNonce {
  id        String   @id @default(cuid())
  state     String   @unique
  nonce     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// A group workstation: several students share one desktop + one persistent volume
// (pair programming, group projects). Every member can open and control the same machine.
model ClassGroup {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  name        String
  volumeId    String? // shared Daytona volume for the group (created on first boot)
  volumeName  String?
  createdAt   DateTime  @default(now())
  students    Student[]
  machines    Machine[]

  @@index([classroomId])
}

// A recurring weekly time slot that auto-boots a class's desktops.
model ClassSchedule {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  weekday     Int // 0=Sunday .. 6=Saturday (server local time)
  startMinute Int // minutes from midnight
  durationMin Int       @default(45)
  endMinute   Int? // optional bell time: auto-shut down the class at this minute-of-day
  os          String    @default("linux")
  enabled     Boolean   @default(true)
  lastRunOn   String? // "YYYY-MM-DD" guard so a slot fires once per day
  lastShutdownOn String? // "YYYY-MM-DD" guard so the bell shutdown fires once per day
  createdAt   DateTime  @default(now())

  @@index([classroomId])
}

// Append-only activity / audit trail for a class.
model ClassEvent {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  studentId   String?
  student     Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  type        String // boot | running | stopped | expired | error | lock | unlock | download | provision_all | shutdown_all
  message     String
  actorRole   String? // teacher | student | system
  createdAt   DateTime  @default(now())

  @@index([classroomId, createdAt])
}

// Scoped API key for the public REST API. Only a SHA-256 hash of the secret is stored;
// the plaintext "rcd_sk_..." is shown to the teacher exactly once at creation.
model ApiKey {
  id         String    @id @default(cuid())
  teacherId  String
  teacher    Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  name       String
  scopes     String // comma-separated scopes, or "*" for all
  hashedKey  String    @unique
  prefix     String // e.g. "rcd_sk_AbC1" — safe to display
  last4      String
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([teacherId])
}

// An outbound webhook endpoint. Subscribed class-activity events are POSTed here, HMAC-signed.
model WebhookEndpoint {
  id         String            @id @default(cuid())
  teacherId  String
  teacher    Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  url        String
  secret     String // HMAC-SHA256 signing secret
  events     String // comma-separated event types, or "*"
  enabled    Boolean           @default(true)
  createdAt  DateTime          @default(now())
  deliveries WebhookDelivery[]

  @@index([teacherId])
}

// One delivery attempt-set for (endpoint, event). Retried with backoff; dead-lettered on exhaustion.
model WebhookDelivery {
  id           String          @id @default(cuid())
  endpointId   String
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  eventId      String // the ClassEvent id (stable across retries)
  eventType    String
  payload      String // JSON body sent
  status       String          @default("pending") // pending | delivered | failed | dead
  attempts     Int             @default(0)
  nextRetryAt  DateTime?
  responseCode Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status, nextRetryAt])
  @@index([endpointId])
}

// Reusable class blueprint a teacher can apply when creating a class.
model ClassTemplate {
  id               String   @id @default(cuid())
  teacherId        String
  teacher          Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  name             String
  os               String   @default("linux")
  durationMin      Int      @default(45)
  allowStudentBoot Boolean  @default(true)
  createdAt        DateTime @default(now())
}

model Student {
  id          String    @id @default(cuid())
  name        String
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  volumeId    String? // Daytona persistent volume id (created on first boot)
  volumeName  String?
  joinedAt    DateTime  @default(now())
  machines    Machine[]

  // Group workstation membership (null = works solo on their own desktop).
  groupId     String?
  group       ClassGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // Monthly desktop-time usage (for plan limits). usageMonth is "YYYY-MM".
  usageMonth   String?
  usageMinutes Int     @default(0)
  events       ClassEvent[]

  // Panic / "raise hand" flag — set when the student asks for help or reports content.
  flaggedAt  DateTime?
  flagKind   String? // help | report
  flagNote   String?

  // Optional bcrypt-hashed join PIN (set when the class requires one).
  joinPin    String?
  // Low-bandwidth desktop streaming preference (persisted per student).
  connectionSaver Boolean @default(false)
  // Private 1:1 message from the teacher to just this student (null = none).
  nudge      String?
  nudgeAt    DateTime?
  // Student "ask for more time" request on their running session (cleared when granted/booted).
  timeRequestAt DateTime?
  // Individual focus lock — teacher freezes just this student's screen (vs the whole class).
  lockedAt   DateTime?
  lockMessage String?

  // OneRoster/SIS identity + soft-delete marker for roster sync de-provisioning.
  sourcedId  String?
  archivedAt DateTime?
  submissions Submission[]
  // LTI user id (the launch `sub`), needed to address this student for AGS grade passback.
  ltiUserId  String?

  @@unique([classroomId, name]) // one identity per name within a class
  @@index([sourcedId])
}

// One machine row per (active) desktop. Status drives the UI lifecycle.
model Machine {
  id           String    @id @default(cuid())
  classroomId  String
  classroom    Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  studentId    String?
  student      Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  // Set instead of studentId when this is a shared group workstation.
  groupId      String?
  group        ClassGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  os           String    @default("linux") // linux | windows
  status       String    @default("PENDING") // PENDING, PROVISIONING, RUNNING, STOPPING, STOPPED, EXPIRED, ERROR
  sandboxId    String? // Daytona sandbox id
  previewUrl   String? // same-origin proxied noVNC url to embed
  previewToken String? // Daytona private-preview token (injected by the proxy)
  errorMessage String?

  durationMin  Int       @default(60) // time limit in minutes
  startedAt    DateTime?
  expiresAt    DateTime? // hard stop time = startedAt + durationMin
  stoppedAt    DateTime?
  watchedUntil DateTime? // set by a teacher viewing/controlling; powers the student "being watched" banner

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([classroomId])
  @@index([studentId])
  @@index([groupId])
  @@index([status])
}

// Singleton heartbeat written by the in-process sweeper, so /api/health/ready can tell
// whether background processing is alive across requests on the single Node process.
model SweeperRun {
  id             String    @id // always "singleton"
  lastStartedAt  DateTime?
  lastFinishedAt DateTime?
  lastError      String?
  durationMs     Int       @default(0)
  ticks          Int       @default(0)
}

// A live formative-assessment poll / exit ticket pushed to every student in a class.
model Poll {
  id          String         @id @default(cuid())
  classroomId String
  classroom   Classroom      @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  prompt      String
  type        String         @default("mcq") // mcq | short
  options     Json? // string[] for mcq
  openedAt    DateTime       @default(now())
  closedAt    DateTime?
  responses   PollResponse[]

  @@index([classroomId])
}

model PollResponse {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  studentId String
  choice    Int? // selected option index (mcq)
  text      String? // free text (short answer)
  createdAt DateTime @default(now())

  @@unique([pollId, studentId])
}

// Short-lived LTI Deep Linking session: holds the LMS return URL + opaque data between the
// DeepLinkingRequest launch and the teacher's content-item selection.
model LtiDeepLinkSession {
  id           String    @id @default(cuid())
  platformId   String
  deploymentId String
  returnUrl    String
  data         String?
  teacherId    String
  usedAt       DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
}
