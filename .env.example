# Copy to .env and fill in. Never commit .env.

# Postgres connection string. The included docker-compose / docker run uses port 5544.
DATABASE_URL="postgresql://postgres:postgres@localhost:5544/remote_classroom"

# Daytona API key from https://app.daytona.io (Settings -> API Keys). Server-side only.
DAYTONA_API_KEY="dtn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Daytona region target (default us)
DAYTONA_TARGET="us"

# Secret used to sign session JWTs. Use a long random string in production.
JWT_SECRET="generate_a_long_random_string"

# Public base URL of this app
APP_URL="http://localhost:3000"

# Stripe (optional). The free tier works without these; set them to enable Pro upgrades.
#   STRIPE_SECRET_KEY     — sk_test_... (or sk_live_...)
#   STRIPE_WEBHOOK_SECRET — whsec_... from `stripe listen` or your dashboard webhook
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
